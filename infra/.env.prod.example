# =========================================================================
# Yonetio — URETIM ortam degiskenleri
#   cp .env.prod.example .env.prod && $EDITOR .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# SIRLAR ASLA repoya girmez — bu dosya yalniz ORNEKTIR (.env.prod .gitignore'da).
# Guclu deger uretimi:  openssl rand -base64 36   (ya da -hex 24)
# =========================================================================

# --- Zaman dilimi --------------------------------------------------------- #
TZ=Europe/Istanbul

# --- Alan adlari (DNS A kaydi bu sunucunun genel IP'sine bakmali) --------- #
# pfSense YALNIZ 80/443'u bu sunucuya iletir; ucu de ayni IP'ye cozulmeli.
API_DOMAIN=api.yonetio.site
PANEL_DOMAIN=panel.yonetio.site
STORAGE_DOMAIN=storage.yonetio.site

# Let's Encrypt kayit/uyari e-postasi (sertifika suresi dolarken bildirim).
ACME_EMAIL=devops@yonetio.site

# --- Postgres OWNER (superuser; migration'lar bununla, RLS bypass) -------- #
POSTGRES_USER=tesis_owner
# openssl rand -base64 36
POSTGRES_PASSWORD=DEGISTIR_guclu_owner_parolasi
POSTGRES_DB=tesis

# --- Uygulama rolu (app_rw; RLS'e TABI; uygulama bununla baglanir) -------- #
APP_DB_USER=app_rw
# openssl rand -base64 36
APP_DB_PASSWORD=DEGISTIR_guclu_app_rw_parolasi

# --- JWT imzalama sirri (32+ karakter, rastgele) -------------------------- #
# openssl rand -base64 48
JWT_SECRET=DEGISTIR_uzun_rastgele_jwt_sirri_min_32_char

# --- NTAG424 SDM/SUN KEK (checkpoint etiket anahtar sifreleme; 32+ char) -- #
# openssl rand -base64 36
SDM_KEK=DEGISTIR_rastgele_32char_sdm_kek

# --- CORS ----------------------------------------------------------------- #
# Tarayicidan API'ye dogrudan cagri icin izinli origin(ler). Panel BFF sunucu
# tarafi cagirdigindan cogu akis buna ihtiyac duymaz; yine de panel origin'i
# verilir. Virgulle birden fazla eklenebilir.
CORS_ORIGINS=https://panel.yonetio.site

# --- MinIO (S3-uyumlu foto deposu) ---------------------------------------- #
MINIO_ROOT_USER=yonetio_minio
# openssl rand -base64 36   (en az 8 karakter — MinIO sarti)
MINIO_ROOT_PASSWORD=DEGISTIR_guclu_minio_parolasi
MINIO_BUCKET=tesis-foto
# PUBLIC presigned URL host'u — istemci (mobil/tarayici) buraya PUT/GET yapar.
# Caddy bu alt-alani minio:9000'e (Host korunarak) proxy'ler. https OLMALI.
MINIO_PUBLIC_URL=https://storage.yonetio.site

# --- Push (FCM) ----------------------------------------------------------- #
# Varsayilan noop (push kapali; hicbir sey cokmez). GERCEK FCM icin:
#   1) Firebase service-account JSON'unu su yola koyun:
#        infra/secrets/fcm-service-account.json
#      (infra/secrets/ klasoru api & worker'a /secrets olarak read-only mount edilir)
#   2) PUSH_PROVIDER=fcm yapin.
# project_id JSON dosyasindan okunur; istege bagli override: FCM_PROJECT_ID.
PUSH_PROVIDER=noop
FCM_PROJECT_ID=
# Genelde degistirmeyin (compose /secrets/fcm-service-account.json'a isaret eder).
FCM_SERVICE_ACCOUNT_PATH=/secrets/fcm-service-account.json

# --- Odeme saglayici (opsiyonel; gercek anahtar yoksa manual birakin) ----- #
PAYMENT_PROVIDER=manual
IYZICO_API_KEY=
IYZICO_SECRET=
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=

# --- Yedekleme (infra/backup.sh) ------------------------------------------ #
# pg_dump ciktisini gpg simetrik sifreleyen parola. GUCLU olmali; bu parola
# KAYBOLURSA yedekler GERI YUKLENEMEZ. Ayri/guvenli yerde saklayin.
# openssl rand -base64 36
BACKUP_GPG_PASSPHRASE=DEGISTIR_yedek_sifreleme_parolasi
# Yedeklerin yazilacagi dizin (sunucuda kalici disk).
BACKUP_DIR=/opt/yonetio/backups
