# /infra/.env.example — `cp .env.example .env` ile kopyalayin ve degerleri degistirin.
# docker compose bu dosyayi otomatik okur (ayni dizinde calistirildiginda).

# --- Postgres OWNER (superuser; migration'lar bununla calisir, RLS bypass) ---
POSTGRES_USER=tesis_owner
POSTGRES_PASSWORD=owner_secret_change_me
POSTGRES_DB=tesis

# --- Uygulama rolu (app_rw; RLS'e TABI; uygulama bununla baglanir) ---
APP_DB_USER=app_rw
APP_DB_PASSWORD=app_rw_secret_change_me

# --- JWT (token uretimi Prompt 2'de) ---
JWT_SECRET=change-me-please-use-a-long-random-32+char-secret

# --- NTAG424 SDM/SUN dogrulamasi ---
# Checkpoint etiket anahtarlarini sifreleyen KEK (32+ karakter, rastgele uret).
# Bos birakilirsa anahtar kaydi (PUT /checkpoints/{id}/sdm-key) 500 config_error.
SDM_KEK=change-me-random-32+chars-sdm-key-encryption-key

# --- MinIO (S3-uyumlu foto kanit deposu) ---
# Kok kimlik (minio container) — api/worker presign icin AYNI degerleri kullanir.
# Parola en az 8 karakter olmali (MinIO sarti).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin12345
MINIO_BUCKET=tesis-foto
# IC AG endpoint (api/worker -> minio); sunucu-tarafi cagri icin (su an kullanilmiyor).
MINIO_INTERNAL_ENDPOINT=http://minio:9000
# PUBLIC endpoint — presigned URL host'u; istemcinin (mobil/tarayici) erisebildigi adres.
# Yerel gelistirmede host'a maplenen port: http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# NOT: compose her MinIO degiskenine inline varsayilan (:-) verir; bu yuzden .env
# eksik olsa bile servisler bos deger ALMAZ ("not set" WARN olusmaz).

# --- Odeme saglayici (kart) — GERCEK ANAHTAR YOK (placeholder) ---
# manual | iyzico | paytr. Gercek tahsilat anahtarlar gelince (sandbox) denenecek.
PAYMENT_PROVIDER=manual
IYZICO_API_KEY=sandbox-iyzico-key
IYZICO_SECRET=sandbox-iyzico-secret
PAYTR_MERCHANT_ID=sandbox-mid
PAYTR_MERCHANT_KEY=sandbox-paytr-key
PAYTR_MERCHANT_SALT=sandbox-paytr-salt

# --- Push saglayici (FCM) — GERCEK KIMLIK YOK (placeholder) ---
# noop | fcm. Kimlik (project_id + service account json) bossa FcmProvider
# unconfigured -> no-op (sessiz cokme yok). Gercek Firebase kimligi gelince fcm'e alinir.
PUSH_PROVIDER=noop
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=
FCM_BASE_URL=https://fcm.googleapis.com

# NOT: DB/Redis URL'leri docker-compose.yml icinde yukaridaki degiskenlerden
# turetilir (servis hostname'leri: db, redis). Burada ayrica tanimlamaya gerek yok.
